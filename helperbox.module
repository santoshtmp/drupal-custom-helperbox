<?php

/**
 * @file
 * Main module file for Helperbox.
 *
 * This file bootstraps the module by including all hook files from the
 * includes/ directory. Individual hook implementations are organized into
 * separate files based on their type.
 */

// Include all hook implementation files.
$includes_path = __DIR__ . '/includes';
foreach (['theme', 'preprocess', 'views', 'entity', 'form', 'menu', 'page'] as $file) {
    $include_file = $includes_path . '/helperbox.' . $file . '.inc';
    if (file_exists($include_file)) {
        require_once $include_file;
    }
}
